# ---------------------------------------------------------------------------
# Build Deep Learning From Scratch — .gitignore
# Commit code, math, and answers. Ignore environments, caches, datasets, and
# generated artifacts.
# ---------------------------------------------------------------------------

# --- Python bytecode / caches ----------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Virtual environments --------------------------------------------------
.venv/
venv/
env/
ENV/
.env
.python-version

# --- Packaging / build -----------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# --- Test / coverage / type-check caches -----------------------------------
.pytest_cache/
.cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.hypothesis/

# --- Notebooks -------------------------------------------------------------
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Datasets — never commit raw data (downloaded per ENVIRONMENT.md)
# ---------------------------------------------------------------------------
data/
datasets/
*.gz
*.tar
*.tar.gz
*.tgz
*.zip
*.npz
*.npy
*.idx
*-ubyte
*-idx*-ubyte
cifar-10-batches-py/
cifar-10-python/
MNIST/
mnist/

# ---------------------------------------------------------------------------
# Generated artifacts — plots, checkpoints, logs
# ---------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.pdf
*.svg
checkpoints/
*.ckpt
*.pt
*.pth
*.pkl
*.pickle
*.npz.weights
logs/
runs/
*.log

# Keep curated, intentionally-committed figures (e.g. docs assets) by force-add:
#   git add -f docs/figures/diagram.png

# ---------------------------------------------------------------------------
# Editor / OS cruft
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
